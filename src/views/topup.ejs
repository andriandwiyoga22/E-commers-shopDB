<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f2f5; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh;">

    <div style="background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center;">
        
        <h1 style="color: #333; margin-bottom: 10px;">Top Up Saldo</h1>
        <p style="color: #666; margin-bottom: 30px;">Tambahkan dana ke akun Anda dengan mudah.</p>

        <form action="/topup" method="POST" style="display: flex; flex-direction: column; align-items: stretch;">
            
            <div style="text-align: left; margin-bottom: 20px;">
                <label for="amount" style="display: block; margin-bottom: 8px; font-weight: bold; color: #555;">Nominal Top Up ($)</label>
                <input type="number" id="amount" name="amount" placeholder="Contoh: 500" required
                    style="width: 100%; padding: 12px; border: 2px solid #eee; border-radius: 8px; font-size: 16px; box-sizing: border-box; transition: border-color 0.3s;">
            </div>

            <button type="submit" 
                onmouseover="this.style.backgroundColor='#72a000'; this.style.transform='translateY(-2px)'"
                onmouseout="this.style.backgroundColor='#adff2f'; this.style.transform='translateY(0)'"
                style="background-color: greenyellow; color: black; padding: 12px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 12px rgba(173, 255, 47, 0.4);">
                Konfirmasi Top Up
            </button>
        </form>

        <div style="margin-top: 25px; border-top: 1px solid #eee; padding-top: 20px;">
            <a href="/dashboard" 
                onmouseover="this.style.color='#333'"
                onmouseout="this.style.color='#808080'"
                style="text-decoration: none; color: #808080; font-size: 14px; transition: 0.3s; font-weight: 500;">
                ← Kembali ke Dashboard
            </a>
        </div>
    </div>

</body>

</html>