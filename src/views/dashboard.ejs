<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body style="font-family: 'Segoe UI', sans-serif; background-color: #f0f2f5; margin: 0; padding: 0;">

    <div style="max-width: 800px; margin: 50px auto; padding: 20px;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <div>
                <h1 style="margin: 0; color: #333;">User Dashboard</h1>
                <p style="margin: 5px 0 0 0; color: #666;">Selamat datang kembali, <strong><%= user.username %></strong>!</p>
            </div>
            <a href="/" style="text-decoration: none; color: #555; font-weight: 600; padding: 8px 16px; background: white; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">← Back to Shop</a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
            
            <div style="background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-left: 5px solid greenyellow;">
                <p style="margin: 0; color: #888; font-size: 14px; text-transform: uppercase; font-weight: bold;">Total Balance</p>
                <h2 style="margin: 10px 0; color: #333; font-size: 32px;">$<%= user.money %></h2>
                <a href="/topup" style="text-decoration: none; color: #81b201; font-weight: 600; font-size: 14px;">+ Top Up Balance</a>
            </div>

            <div style="background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-left: 5px solid #333;">
                <p style="margin: 0; color: #888; font-size: 14px; text-transform: uppercase; font-weight: bold;">Account Role</p>
                <h2 style="margin: 10px 0; color: #333; font-size: 32px; text-transform: capitalize;"><%= user.role %></h2>
                
                <% if (user.role === 'user') { %>
                    <form action="/dashboard" method="POST" style="margin-top: 10px;">
                        <input type="hidden" name="role" value="seller">
                        <button type="submit" style="background: none; border: none; color: #007bff; padding: 0; font-weight: 600; cursor: pointer; font-size: 14px;">Mulai Berjualan (Jadi Seller) →</button>
                    </form>
                <% } else { %>
                    <span style="color: #2ecc71; font-size: 14px; font-weight: 600;">✓ Seller Active</span>
                <% } %>
            </div>
        </div>

        <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
            <h3 style="margin-top: 0; color: #333; margin-bottom: 20px;">Quick Actions</h3>
            
            <div style="display: flex; flex-wrap: wrap; gap: 15px;">
                <% if (user.role === 'seller') { %>
                    <a href="/products" 
                        onmouseover="this.style.backgroundColor='#81b201'; this.style.color='white'"
                        onmouseout="this.style.backgroundColor='#adff2f'; this.style.color='black'"
                        style="text-decoration: none; background-color: greenyellow; padding: 12px 25px; border-radius: 10px; transition: 0.3s; color: black; font-weight: bold; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                        📦 Kelola Produk
                    </a>
                <% } %>

                <a href="/shoppingCart" 
                    onmouseover="this.style.backgroundColor='#333'; this.style.color='white'"
                    onmouseout="this.style.backgroundColor='#f0f0f0'; this.style.color='#333'"
                    style="text-decoration: none; background-color: #f0f0f0; padding: 12px 25px; border-radius: 10px; transition: 0.3s; color: #333; font-weight: bold;">
                    🛒 Keranjang Saya
                </a>

                <a href="/logout" 
                    onmouseover="this.style.backgroundColor='#c0392b'"
                    onmouseout="this.style.backgroundColor='#e74c3c'"
                    style="text-decoration: none; background-color: #e74c3c; padding: 12px 25px; border-radius: 10px; transition: 0.3s; color: white; font-weight: bold; margin-left: auto;">
                    Logout
                </a>
            </div>
        </div>
    </div>

</body>

</html>