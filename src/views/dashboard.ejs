<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <link rel="shortcut icon" href="https://img.icons8.com/?size=100&id=iXgIlTTMZtTO&format=png&color=000000" type="image/x-icon">
    <title>User Dashboard</title>
    <style>
        /* Base Styles */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            padding: 0;
            color: #333;
        }

        .container {
            max-width: 800px;
            margin: 20px auto;
            padding: 15px;
        }

        /* Header Section */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            gap: 15px;
        }

        .back-btn {
            text-decoration: none;
            color: #555;
            font-weight: 600;
            padding: 10px 18px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            white-space: nowrap;
            font-size: 14px;
            transition: transform 0.2s;
        }

        .back-btn:hover {
            transform: translateY(-2px);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: scale 0.2s;
        }

        .card-balance { border-left: 6px solid #adff2f; }
        .card-role { border-left: 6px solid #333; }

        .label {
            margin: 0;
            color: #888;
            font-size: 13px;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        .value {
            margin: 10px 0;
            color: #222;
            font-size: 28px;
            word-break: break-all;
        }

        /* Action Buttons */
        .quick-actions {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .btn-group {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .btn {
            text-decoration: none;
            padding: 12px 20px;
            border-radius: 10px;
            font-weight: bold;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            flex-grow: 1;
            text-align: center;
        }

        .btn-manage { background-color: #adff2f; color: #000; }
        .btn-manage:hover { background-color: #81b201; color: #fff; }

        .btn-cart { background-color: #f0f0f0; color: #333; }
        .btn-cart:hover { background-color: #333; color: #fff; }

        .btn-logout { background-color: #e74c3c; color: white; }
        .btn-logout:hover { background-color: #c0392b; }

        /* Responsive Breakpoints */
        @media (max-width: 600px) {
            .header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .back-btn {
                width: 100%;
                text-align: center;
                box-sizing: border-box;
            }

            .btn-group {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                margin-left: 0 !important; 
            }

            .value {
                font-size: 24px;
            }
        }
    </style>
</head>

<body>

    <div class="container">
        
        <div class="header">
            <div>
                <h1 style="margin: 0;">User Dashboard</h1>
                <p style="margin: 5px 0 0 0; color: #666;">Selamat datang kembali, <strong><%= user.username %></strong>!</p>
            </div>
            <a href="/" class="back-btn">← Back to Shop</a>
        </div>

        <div class="stats-grid">
            
            <div class="card card-balance">
                <p class="label">Total Balance</p>
                <h2 class="value">$<%= user.money %></h2>
                <a href="/topup" style="text-decoration: none; color: #81b201; font-weight: 700; font-size: 14px;">+ Top Up Balance</a>
            </div>

            <div class="card card-role">
                <p class="label">Account Role</p>
                <h2 class="value" style="text-transform: capitalize;"><%= user.role %></h2>
                
                <% if (user.role === 'user') { %>
                    <form action="/dashboard" method="POST">
                        <input type="hidden" name="role" value="seller">
                        <button type="submit" style="background: none; border: none; color: #007bff; padding: 0; font-weight: 600; cursor: pointer; font-size: 14px; text-decoration: underline;">Mulai Berjualan (Jadi Seller) →</button>
                    </form>
                <% } else { %>
                    <span style="color: #2ecc71; font-size: 14px; font-weight: 600;">✓ Seller Active</span>
                <% } %>
            </div>
        </div>

        <div class="quick-actions">
            <h3 style="margin-top: 0; margin-bottom: 20px; font-size: 18px;">Quick Actions</h3>
            
            <div class="btn-group">
                <% if (user.role === 'seller') { %>
                    <a href="/products" class="btn btn-manage">📦 Kelola Produk</a>
                <% } %>

                <a href="/shoppingCart" class="btn btn-cart">🛒 Keranjang Saya</a>

                <a href="/logout" class="btn btn-logout" style="margin-left: auto;">Logout</a>
            </div>
        </div>
    </div>

</body>
</html>